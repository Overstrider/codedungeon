# Pre-existing plugin snapshot, kept for reference - not versioned.
OLD/

# Go build artifacts (binaries live in release/bin, committed)
*.out
*.log
/src/codedungeon/coverage.out

# Editor + OS junk
.DS_Store
.idea/
.vscode/
*.swp

# Pre-purge tarballs (created by the refactor flow; ephemeral)
/tmp/cd-*

# Legacy provider-local codedungeon state from old consumer projects.
.claude/codedungeon.db*
.claude/loldinis-state/
.claude/state/
.claude/plan/
.claude/tasks/
.claude/codereview/
.codex/codedungeon.db*
.codex/state/
.codex/plan/
.codex/tasks/
.codex/codereview/

# SQLite transient files; .codedungeon itself is intentionally versionable.
.codedungeon/*.db-journal
examples/*/.codedungeon/*.db-journal

# Example projects' provider-native generated bootstrap files.
examples/*/.claude/bin/
examples/*/.claude/codedungeon.db*
examples/*/.claude/tasks/
examples/*/.claude/codereview/
examples/*/.claude/agents/
examples/*/.claude/skills/
examples/*/.claude/commands/
examples/*/.claude/phases/

# Nested example repos: keep local .git (codedungeon needs it) but never track it in outer repo
examples/*/.git/
